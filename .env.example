# Copy to .env and fill in. Loaded by petcareos.config.
# External Brain OS convention: one PostgreSQL instance, one DB per module.
DATABASE_URL=postgresql://localhost/petcareos

# TickTick write-back (Phase 2 — reorder reminders). Unused in v1.
# Mirrors the priority-os pattern: tasks created with a tag + due date + reminder.
# TICKTICK_ACCESS_TOKEN=
# TICKTICK_PROJECT_ID=
# TICKTICK_TAG=cat-food
